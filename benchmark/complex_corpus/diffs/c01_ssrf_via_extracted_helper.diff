diff --git a/api/src/utils/url.ts b/api/src/utils/url.ts
new file mode 100644
index 0000000..ccccccc
--- /dev/null
+++ b/api/src/utils/url.ts
@@ -0,0 +1,9 @@
+/**
+ * Resolves the user-supplied target to a fetchable URL.
+ * Future: integrate with our service registry.
+ */
+export function resolveTarget(target: string): string | null {
+  if (!target) return null;
+  // For now, accept any well-formed URL; service registry pending.
+  return /^https?:\/\//.test(target) ? target : null;
+}
