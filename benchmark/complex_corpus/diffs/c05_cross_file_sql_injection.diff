+export async function reportByDateRange(filter: { from: string; to: string; tenant?: string }) {
+  const tenantClause = filter.tenant ? `AND tenant_id = '${filter.tenant}'` : '';
+  return sequelize.query(
+    `SELECT id, total FROM orders WHERE created_at BETWEEN :from AND :to ${tenantClause}`,
+    { replacements: { from: filter.from, to: filter.to }, type: 'SELECT' },
+  );
 }
